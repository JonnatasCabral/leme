# URL e chaves do projeto Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Chave service_role (NUNCA exponha no client, só em rotas de API/server)
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# URL pública do site (usada para montar links de compartilhamento)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — assinatura do plano Pro (ver seção "Billing" no SETUP.md)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...
